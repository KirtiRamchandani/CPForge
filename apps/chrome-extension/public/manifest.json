{
  "manifest_version": 3,
  "name": "CP Forge Companion",
  "description": "Local-first Codeforces and LeetCode practice sidebar, notes, mistakes, review, and upsolve tracking.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://codeforces.com/*", "https://leetcode.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*", "https://leetcode.com/*"],
      "js": ["src/content.ts"],
      "css": ["src/sidebar.css"]
    }
  ]
}

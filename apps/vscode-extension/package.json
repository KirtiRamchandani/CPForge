{
  "name": "@cp-forge/vscode-extension",
  "displayName": "CP Forge VS Code",
  "description": "Track CP solving sessions, notes, mistakes, reviews, upsolve, and local samples from VS Code.",
  "version": "0.1.0",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:cpForge.startProblem"],
  "contributes": {
    "commands": [
      { "command": "cpForge.startProblem", "title": "CP Forge: Start Problem" },
      { "command": "cpForge.addMistake", "title": "CP Forge: Add Mistake" },
      { "command": "cpForge.addNote", "title": "CP Forge: Add Note" },
      { "command": "cpForge.markSolved", "title": "CP Forge: Mark Solved" },
      { "command": "cpForge.showChecklist", "title": "CP Forge: Show Checklist" },
      { "command": "cpForge.exportSession", "title": "CP Forge: Export Session" }
    ]
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --external vscode --clean",
    "dev": "tsup src/extension.ts --format cjs --external vscode --watch",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0"
  }
}
